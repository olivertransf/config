#!/usr/bin/env sh
# Minimal tiling. (Opacity block commented out below.) Backup: ~/.config/yabai/yabairc.backup-*

# Scripting addition (space focus, warps, etc. on Apple Silicon need nvram + load-sa).
# One-time setup (nvram + sudoers, then reboot if nvram changed): ~/.config/yabai/install-yabai-sa.sh
# After each yabai upgrade: re-run install-yabai-sa.sh (sudoers hash changes).
YABAI_LOAD_SA="$HOME/.config/yabai/load-sa.sh"
yabai -m signal --add event=dock_did_restart action="sh $HOME/.config/yabai/load-sa.sh; yabai -m config layout bsp"
sh "$YABAI_LOAD_SA"

yabai -m config layout                 bsp
yabai -m config window_placement       second_child
yabai -m config auto_balance           off
yabai -m config split_ratio            0.50

yabai -m config window_gap             0
yabai -m config top_padding            0
yabai -m config bottom_padding         0
yabai -m config left_padding           0
yabai -m config right_padding          0

yabai -m config mouse_follows_focus    off
yabai -m config focus_follows_mouse    off
yabai -m config window_shadow          on

yabai -m rule --add app="^System Settings$"     manage=off
yabai -m rule --add app="^System Preferences$" manage=off
# 1Password (app + unlock/quick windows) — float, don’t tile
yabai -m rule --add app="^1Password" manage=off
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="^Google Drive$" manage=off
yabai -m rule --add app="^App Store$" manage=off
yabai -m rule --add app="^Messages$" manage=off
yabai -m rule --add app="^QuickTime Player$" manage=off
yabai -m rule --add app="^Simulator$" manage=off
yabai -m rule --add app="^Weather$" manage=off
yabai -m rule --add app="^TheBoringNotch$" manage=off
yabai -m rule --add app="^boringNotch$" manage=off
yabai -m rule --add app="^Karabiner" manage=off
yabai -m rule --add app="^Wallspace$" manage=off
yabai -m rule --add app="^Tailscale$" manage=off
yabai -m rule --add app="^Garmin Express" manage=off
yabai -m rule --add app="^Photos$" manage=off
yabai -m rule --add app="^The Unarchiver$" manage=off
# Zen (Firefox-based) — picture-in-picture; don’t tile (same title as Firefox PiP)
yabai -m rule --add app="^Zen$" title="^(Picture-in-Picture)$" manage=off

